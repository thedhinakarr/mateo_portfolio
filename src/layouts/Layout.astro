---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Tvättbjörne | Tak-, fasad- och altantvätt",
  description = "Tvättbjörne erbjuder proffsig tvätt av tak, fasad, altan, mark, mur och textil med kostnadsfri offert."
} = Astro.props;
---

<!doctype html>
<html lang="sv">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="theme-color" content="#2f9d46" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
  </body>
</html>
